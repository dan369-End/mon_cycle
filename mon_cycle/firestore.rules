rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Match the user document
    match /users/{userId} {
      // Allow the user to read/write their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Recursive wildcard to match ALL subcollections (settings, history, etc.) nested under the user
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}